{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QIKVRT GitHub Remote Effect Evidence V45.12",
  "type": "object",
  "required": [
    "evidence_version",
    "status",
    "release_claim",
    "real_remote_effects",
    "repository_url",
    "target_branch",
    "local_commit_sha",
    "remote_commit_sha",
    "pushed_ref_verified",
    "release_tag",
    "release_id",
    "release_url",
    "release_target_commitish",
    "acceptance",
    "uploaded_assets"
  ],
  "properties": {
    "evidence_version": {
      "const": "QIKVRT_GITHUB_REMOTE_EFFECT_EVIDENCE_V45_12"
    },
    "status": {
      "const": "PASS"
    },
    "release_claim": {
      "const": true
    },
    "real_remote_effects": {
      "const": true
    },
    "repository_url": {
      "type": "string",
      "minLength": 1
    },
    "target_branch": {
      "type": "string",
      "minLength": 1
    },
    "local_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40,64}$"
    },
    "remote_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40,64}$"
    },
    "pushed_ref_verified": {
      "const": true
    },
    "release_tag": {
      "type": "string",
      "minLength": 1
    },
    "release_id": {
      "type": [
        "string",
        "integer"
      ],
      "minLength": 1
    },
    "release_url": {
      "type": "string",
      "pattern": "^https://github\\.com/.+/.+/releases/tag/.+"
    },
    "release_target_commitish": {
      "type": "string",
      "minLength": 1
    },
    "acceptance": {
      "type": "object"
    },
    "uploaded_assets": {
      "type": "array",
      "minItems": 1
    }
  }
}