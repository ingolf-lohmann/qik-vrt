{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Goldkelch/qik-vrt/schemas/human_machine_progress.schema.json",
  "title": "QIK-VRT Human-Machine Progress",
  "type": "object",
  "required": ["schema", "repository", "operation", "status", "gates"],
  "properties": {
    "schema": {"const": "qikvrt_human_machine_progress_v1"},
    "repository": {"type": "string", "minLength": 3},
    "operation": {"type": "string", "minLength": 1},
    "status": {"enum": ["IN_PROGRESS", "PASS", "BLOCK", "FAIL", "TIMEOUT"]},
    "progressPercent": {"type": "integer", "minimum": 0, "maximum": 100},
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "state"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "state": {"enum": ["PENDING", "RUNNING", "PASS", "BLOCK", "FAIL", "SKIPPED"]},
          "evidence": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
