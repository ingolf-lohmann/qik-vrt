    "metadata": {
      "title": "QIK-VRT: Quellengebundene partielle Lean-4-Formalisierung des 62-seitigen Manuskripts – Alpha 2 mit EFFECT_ACK-Kern",
      "upload_type": "software",
      "publication_date": "2026-07-23",
