  "cross_platform_fix_mirror_rule": {
    "id": "QALL_CROSS_PLATFORM_FIX_MIRROR",
    "status": "IMPLEMENTED",
    "rule": "Every Linux sandbox bugfix must be mirrored to Windows and macOS where relevant.",
    "findings": [
      {
        "id": "F012_WINDOWS_INI_FIX_NOT_FULLY_MIRRORED",
        "severity": "BLOCK_RELEASE_UNTIL_FIXED",
        "finding": "Linux INI/persist=false logic existed, but Windows RUN.ps1 was not guaranteed to implement equivalent robust INI behavior.",
        "required_fix": "Rewrite/patch Windows RUN.ps1 to parse QALL.ini, support MANUAL target and persist=false, same logs and payload/internal paths."
      }
    ],
    "fixes": [
      "Windows RUN.ps1 now implements same QALL.ini MANUAL target logic as Linux RUN.sh.",
      "Windows RUN.ps1 now implements same persist=false GitHub skip behavior as Linux RUN.sh.",
      "Windows RUN.ps1 writes same LOGS/TARGET.json, LOGS/REPO_OUT.zip, LOGS/STATUS.txt.",
      "macOS launcher delegates to same fixed _payload/_internal/RUN.sh with root argument.",
      "GitHub target list includes CROSSFIX metadata."
    ],
    "acceptance": {
      "linux_runtime_test_required": true,
      "windows_static_parity_required": true,
      "macos_static_parity_required": true,
      "no_unmirrored_linux_fix_allowed": true
    }
  },
  "unmirrored_linux_fix_is_reflexive_error": true,
