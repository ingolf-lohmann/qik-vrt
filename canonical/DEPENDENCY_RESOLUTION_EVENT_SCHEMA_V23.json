  "schema": "qikvrt_dependency_resolution_event_schema_v23",
  "required_fields": [
    "dependency_id",
    "dependency_type",
    "required_for",
    "platform_scope",
    "preferred_embedded_paths",
    "fallback_discovery_commands",
    "download_allowed_after_consent",
    "license_area",
