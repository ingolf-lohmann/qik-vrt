  "required_events": [
    "dependency_resolution_start",
    "dependency_discovery_result",
    "dependency_download_consent_required",
    "dependency_download_start",
    "dependency_download_end",
    "dependency_resolution_end"
  ],
  "non_dead_block_rule": "If a dependency cannot be resolved, emit CONTINUE with continue_path, repair_hint and evidence_file."
}
