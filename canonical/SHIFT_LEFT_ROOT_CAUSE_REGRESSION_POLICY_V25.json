  "status": "ACTIVE",
  "rule": "A repair is not complete until regression tests catch the root cause before manual field testing.",
  "required_scenarios": [
    "no_argument_double_click_defaults_to_master_gate",
    "missing_runtime_produces_continue_and_run_end",
    "python_target_nonzero_produces_wrapper_end_and_run_end",
    "jsonl_parseability",
    "single_canonical_run_end",
    "nonzero_never_done",
    "repair_hint_present",
    "continue_path_present",
    "general_dependency_contract_visible",
    "regression_harness_timeout_bounded"
  ],
  "forbidden": [
    "manual_field_test_required_to_find_basic_launcher_error",
    "wrapper_end_without_run_end",
    "shift_left_regression_gate_missing",
    "CI_DEVOPS_SHIT_LEFT_INSTEAD_OF_SHIFT_LEFT",
    "unbounded_subprocess_in_master_gate",
    "implicit_python_package_import_in_harness"
  ],
  "qed": "Continuous Integration und DevOps heißen Shift left, nicht Shit left. q.e.d. Ingolf Lohmann"
