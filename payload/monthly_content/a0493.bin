name: verify-update-scripts
on: [push, pull_request, workflow_dispatch]
jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: python tools/verify_update_script_package.py

      - run: python tools/verify_cross_platform_executability.py

      - run: python tools/verify_license_compliance.py

      - run: python tools/verify_acceptance_coverage.py

      - run: python tools/qikvrt_master_acceptance_gate.py
