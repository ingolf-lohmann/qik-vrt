      "REPACKAGE",
      "BUILD_ARTIFACT",
      "LOCAL_REPRODUCTION",
      "GITHUB_PERSISTENCE_OUTPUT",
      "REPOSITORY_PAYLOAD",
      "FOLLOW_UP_BUNDLE"
    ],
    "required_files": [
      "BILINGUAL_UI_USER_INFO_STANDARD.json",
