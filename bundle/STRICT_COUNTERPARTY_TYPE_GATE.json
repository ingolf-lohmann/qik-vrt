      "BILINGUAL_UI_INHERITANCE_GATE.json",
      "BILINGUAL_UI_INHERITANCE_GATE.md"
    ],
    "required_user_facing_languages": [
      "de",
      "en"
    ],
    "blocker_error_classes": [
