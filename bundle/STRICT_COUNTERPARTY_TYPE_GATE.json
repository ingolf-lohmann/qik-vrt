      "DERIVED_ARTIFACT_USER_INFO_NOT_BILINGUAL_DE_EN",
      "CLONE_OR_MERGE_DROPPED_BILINGUAL_UI_STANDARD"
    ],
    "release_rule": "No derived artifact may be released unless bilingual DE/EN UI and user-information inheritance is preserved."
  },
  "derived_artifacts_must_inherit_bilingual_ui_de_en": true,
