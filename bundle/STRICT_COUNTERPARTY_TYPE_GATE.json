  "reflexive_finding_workflow_standard": {
    "id": "QALL_REFLEXIVE_FINDING_WORKFLOW_STANDARD",
    "status": "IMPLEMENTED",
    "standard_rule": "If the delivered bundle does not work immediately for the user, every finding is a reflexive error class.",
    "applies_to_events": [
      "DOWNLOAD",
      "UNZIP",
      "START",
      "CONFIGURATION",
      "LICENSE_ACCEPTANCE",
      "COUNTERPARTY_TYPE_CLASSIFICATION",
      "OTHER_COUNTERPARTY_DESCRIPTION",
      "LOGGING",
      "LOCAL_REPRODUCTION",
      "GITHUB_PERSISTENCE",
      "TEMPLATE_USE",
      "CLONE",
      "MERGE",
      "REUSE"
    ],
    "mandatory_correction_layers": [
      "ROOT_DELIVERY_STRUCTURE",
      "PAYLOAD",
      "INTERNAL_SCRIPTS",
      "WINDOWS",
      "LINUX",
      "MACOS",
      "GITHUB_PERSISTENCE_PATH",
      "TEMPLATE_CLONE_DOWNLOAD_USE_MERGE_PRESERVATION",
      "LICENSE_COPYRIGHT_GUARD",
      "STRICT_ACCEPTANCE_GATE",
      "STRICT_COUNTERPARTY_TYPE_GATE",
      "OTHER_COUNTERPARTY_DESCRIPTION_GATE",
      "POLICY",
      "MAP",
      "LEARN",
      "ACCEPT",
      "SYNC",
      "REPORTS",
      "TESTS"
    ],
    "forbidden_fix_classes": [
      "ISOLATED_HOTFIX",
      "LINUX_ONLY_FIX_WHEN_CROSS_PLATFORM_RELEVANT",
      "UNMIRRORED_WINDOWS_MACOS_GITHUB_CLONE_FIX",
      "FALSE_PASS_AFTER_LOCAL_ONLY_PATCH",
      "UNPERSISTED_LEARNING"
    ],
    "required_process": [
      "NAME_FINDING",
      "CLASSIFY_AS_REFLEXIVE_ERROR_CLASS",
      "LOCATE_CAUSE",
      "CORRECT_ALL_RELEVANT_LAYERS",
      "MIRROR_WINDOWS_LINUX_MACOS_WHERE_RELEVANT",
      "UPDATE_GITHUB_TEMPLATE_CLONE_MERGE_PRESERVATION",
      "UPDATE_LICENSE_AND_ACCEPTANCE_GATES_IF_RELEVANT",
      "UPDATE_POLICY_MAP_LEARN_ACCEPT_SYNC_REPORTS",
      "RUN_TESTS",
      "DELIVER_ONLY_ON_PASS"
    ],
    "blocker_error_class": "USER_TEST_FINDING_NOT_REFLEXIVELY_CORRECTED",
    "release_rule": "No new bundle release after a user finding unless the reflexive workflow record and all relevant layer corrections are persisted."
  },
  "user_test_findings_are_reflexive_error_classes": true,
  "isolated_hotfix_allowed": false,
  "bilingual_ui_user_info_standard": {
    "id": "QALL_BILINGUAL_UI_USER_INFO_STANDARD",
    "status": "IMPLEMENTED",
    "languages": [
      "de",
      "en"
    ],
    "rule": {
      "de": "Alle interaktiven Benutzeroberflächen und alle nutzergerichteten Bundle-Informationen müssen zweisprachig Deutsch/Englisch sein.",
      "en": "All interactive user interfaces and all user-facing bundle information must be bilingual German/English."
    },
    "applies_to": [
      "WINDOWS.bat messages",
      "LINUX.sh messages",
      "MACOS.command messages",
      "RUN.sh prompts",
      "RUN.ps1 prompts",
      "README.md",
      "NOTICE",
      "QALL.ini comments",
      "license acceptance notices",
      "counterparty type notices",
      "OTHER description prompts",
      "block/done messages",
      "user-facing logs/status explanations"
    ],
    "machine_artifact_boundary": {
      "de": "Maschinenlesbare JSON-/Manifest-Artefakte dürfen technisch bleiben, müssen aber für nutzerrelevante Aussagen zweisprachige Begleitinformationen tragen.",
      "en": "Machine-readable JSON/manifest artifacts may remain technical, but user-relevant statements must carry bilingual companion information."
    },
    "blocker_error_class": "USER_FACING_TEXT_NOT_BILINGUAL_DE_EN",
    "preserve_in_clones_download_use_merge": true
  },
  "user_facing_text_must_be_bilingual_de_en": true,
  "bilingual_ui_inheritance_gate": {
    "id": "QALL_BILINGUAL_UI_INHERITANCE_GATE",
    "status": "IMPLEMENTED",
    "property": "BILINGUAL_UI_USER_INFO_DE_EN",
