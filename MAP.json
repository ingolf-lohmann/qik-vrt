  "_qikvrt_applies_to_json_data_reports_results": true,
  "id": "QALL_POWERSHELL_LINUX_SANDBOX_1_TO_1_MAPPING",
  "status": "PERSISTED_AS_BUNDLE_AND_REPOSITORY_MAPPING",
  "purpose": "Mirror Windows Batch/PowerShell functions to Linux sandbox functions for verification and development.",
  "principle": "Windows runtime success is not claimed from Linux sandbox equivalence. Linux mapping is functional verification support, not a replacement for real Windows execution.",
  "equivalence_status_values": {
    "EXACT": "Same semantic operation and same relevant result.",
    "FUNCTIONAL": "Different command/runtime, same intended file-system or data result.",
    "PARTIAL": "Can be approximated but not fully proven in the sandbox.",
    "BLOCK": "Cannot be mapped without missing runtime, network, credential, or platform state."
  },
  "items": [
    {
      "id": "MAP001_BAT_ENTRY",
      "purpose": "Start entry point",
      "windows": "START.bat via cmd.exe",
      "powershell_or_cmd": "cmd.exe /c START.bat",
      "linux_sandbox": "python-controlled workflow invoking equivalent steps directly",
      "equivalence": "FUNCTIONAL",
      "boundary": "cmd.exe itself is Windows-only; sandbox mirrors the effects, not the shell runtime."
    },
    {
      "id": "MAP002_POWERSHELL_RUNTIME",
      "purpose": "Run PowerShell script",
      "windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File RUN.ps1",
      "powershell_or_cmd": "powershell.exe",
      "linux_sandbox": "python3 execution of equivalent ZIP/JSON/hash logic",
      "equivalence": "FUNCTIONAL",
      "boundary": "No real Windows PowerShell runtime is executed in this Linux sandbox."
    },
    {
      "id": "MAP003_PATH_ROOT",
      "purpose": "Resolve bundle root",
      "windows": "$Root = Split-Path -Parent $MyInvocation.MyCommand.Path",
      "powershell_or_cmd": "Split-Path",
      "linux_sandbox": "Path('/mnt/data/...').parent or extracted work directory",
      "equivalence": "EXACT",
      "boundary": "Path separator differs; logical root is equivalent."
    },
    {
      "id": "MAP004_REMOVE_DIRECTORY",
      "purpose": "Clean OUT/WORK folders",
      "windows": "Remove-Item -Recurse -Force $Out",
      "powershell_or_cmd": "Remove-Item",
      "linux_sandbox": "shutil.rmtree(path)",
      "equivalence": "EXACT",
      "boundary": "Permission semantics differ only by platform."
    },
    {
      "id": "MAP005_CREATE_DIRECTORY",
      "purpose": "Create directories",
      "windows": "New-Item -ItemType Directory -Force -Path $Out",
      "powershell_or_cmd": "New-Item",
      "linux_sandbox": "Path.mkdir(parents=True, exist_ok=True)",
      "equivalence": "EXACT",
      "boundary": "Directory creation result is equivalent."
    },
    {
      "id": "MAP006_TEST_PATH",
      "purpose": "Check file/path existence",
      "windows": "Test-Path -LiteralPath $RepoZip",
      "powershell_or_cmd": "Test-Path",
      "linux_sandbox": "Path.exists()",
      "equivalence": "EXACT",
      "boundary": "Case sensitivity can differ."
    },
    {
      "id": "MAP007_READ_HOST",
      "purpose": "Interactive user input",
      "windows": "Read-Host",
      "powershell_or_cmd": "Read-Host",
      "linux_sandbox": "parameterized test values or input() equivalent",
      "equivalence": "FUNCTIONAL",
      "boundary": "Noninteractive sandbox tests inject values; interactive console behavior is not identical."
    },
    {
      "id": "MAP008_EXPAND_ARCHIVE",
      "purpose": "Extract ZIP",
      "windows": "Expand-Archive -LiteralPath REPO.zip -DestinationPath WORK",
      "powershell_or_cmd": "Expand-Archive",
      "linux_sandbox": "zipfile.ZipFile(...).extractall(...)",
      "equivalence": "EXACT",
      "boundary": "Both validate/extract ZIP; metadata details may differ."
    },
    {
      "id": "MAP009_COMPRESS_ARCHIVE",
      "purpose": "Create output ZIP",
      "windows": "Compress-Archive -Path ... -DestinationPath OUT\\REPO_OUT.zip",
      "powershell_or_cmd": "Compress-Archive",
      "linux_sandbox": "zipfile.ZipFile(..., 'w', ZIP_DEFLATED)",
      "equivalence": "FUNCTIONAL",
      "boundary": "Byte-identical ZIP is not guaranteed; file content and logical structure are tested."
    },
    {
      "id": "MAP010_HASH_SHA256",
      "purpose": "Create SHA256 sidecar",
      "windows": "Get-FileHash -Algorithm SHA256",
      "powershell_or_cmd": "Get-FileHash",
      "linux_sandbox": "hashlib.sha256(path.read_bytes()).hexdigest()",
      "equivalence": "EXACT",
      "boundary": "Same SHA256 digest algorithm."
    },
    {
      "id": "MAP011_JSON_WRITE",
      "purpose": "Write JSON",
      "windows": "ConvertTo-Json | Set-Content -Encoding UTF8",
      "powershell_or_cmd": "ConvertTo-Json / Set-Content",
      "linux_sandbox": "json.dumps(..., ensure_ascii=False, indent=2); Path.write_text(..., encoding='utf-8')",
      "equivalence": "FUNCTIONAL",
      "boundary": "Formatting may differ; JSON semantics are tested."
    },
    {
      "id": "MAP012_TEXT_WRITE",
      "purpose": "Write status and manifest text",
      "windows": "Set-Content / Add-Content",
      "powershell_or_cmd": "Set-Content",
      "linux_sandbox": "Path.write_text(...)",
      "equivalence": "EXACT",
      "boundary": "Line ending may differ; content semantics are equivalent."
    },
    {
      "id": "MAP013_GITHUB_API_GET",
      "purpose": "Read GitHub content metadata",
      "windows": "Invoke-RestMethod -Method GET",
      "powershell_or_cmd": "Invoke-RestMethod",
      "linux_sandbox": "not executed without credential/network authorization; would map to urllib/requests/web API",
      "equivalence": "BLOCK",
      "boundary": "No GitHub write/read success is claimed without real API execution and credentials."
    },
    {
      "id": "MAP014_GITHUB_API_PUT",
      "purpose": "Persist files to GitHub",
      "windows": "Invoke-RestMethod -Method PUT",
      "powershell_or_cmd": "Invoke-RestMethod",
      "linux_sandbox": "not executed without credential/network authorization; would map to urllib/requests/web API",
      "equivalence": "BLOCK",
      "boundary": "GitHub success remains false until real API PUT succeeds."
    },
    {
      "id": "MAP015_BASE64",
      "purpose": "Base64 encode GitHub API content",
      "windows": "[Convert]::ToBase64String([System.IO.File]::ReadAllBytes(...))",
      "powershell_or_cmd": "[Convert]::ToBase64String",
      "linux_sandbox": "base64.b64encode(path.read_bytes()).decode('ascii')",
      "equivalence": "EXACT",
      "boundary": "Exact content bytes produce exact base64 string."
    },
    {
      "id": "MAP016_ERROR_EXIT",
      "purpose": "Block on hard failure",
      "windows": "exit <code>",
      "powershell_or_cmd": "exit",
      "linux_sandbox": "raise SystemExit(code) or report FAIL",
      "equivalence": "FUNCTIONAL",
      "boundary": "Process runtime differs; status semantics are equivalent."
    },
    {
      "id": "MAP017_STATUS_BOUNDARY",
      "purpose": "No false success claims",
      "windows": "STATUS.txt / MANIFEST.txt written by RUN.ps1",
      "powershell_or_cmd": "Set-Content",
      "linux_sandbox": "JSON report plus status file generation",
      "equivalence": "EXACT",
      "boundary": "No commit/push/upload/release is inferred from local output."
    },
    {
      "id": "MAP018_GITHUB_MAPPING_PERSISTENCE",
      "purpose": "Persist mapping/procedure artefacts to GitHub",
      "windows": "RUN.ps1 optional GitHub API path uploads MAP/LEARN/POLICY/standard files",
      "powershell_or_cmd": "Invoke-RestMethod PUT via PutFile",
      "linux_sandbox": "BLOCK without credentials; statically verified by script scan",
      "equivalence": "BLOCK",
      "boundary": "GitHub success requires real credentials, network, and successful API responses."
    },
    {
      "id": "MAP019_POSIX_LOCAL_REPRODUCTION",
      "purpose": "Linux/macOS local reproduction",
      "windows": "RUN.ps1 local ZIP/JSON/hash workflow",
      "powershell_or_cmd": "PowerShell Expand-Archive/Compress-Archive/Get-FileHash",
      "linux_sandbox": "RUN.sh with unzip/zip/sha256sum or shasum",
      "equivalence": "FUNCTIONAL",
      "boundary": "ZIP bytes may differ; logical files, hash sidecar and status are tested."
    },
    {
      "id": "MAP020_MACOS_LAUNCHER",
      "purpose": "macOS user start",
      "windows": "START.bat",
      "powershell_or_cmd": "cmd.exe wrapper",
      "linux_sandbox": "START.command invokes /bin/sh RUN.sh",
      "equivalence": "FUNCTIONAL",
      "boundary": "macOS runtime not executed in this Linux sandbox."
    },
    {
      "id": "MAP021_SYNC_LAYER_DISCLOSURE",
      "purpose": "Expose missing or untested platform layers",
      "windows": "STATUS/MANIFEST boundary lines",
      "powershell_or_cmd": "Set-Content",
      "linux_sandbox": "SYNC.json/SYNC.md plus test report",
      "equivalence": "EXACT",
      "boundary": "No platform DONE unless platform executed."
    },
    {
      "id": "MAP022_TOKEN_ONLY_WINDOWS_GITHUB",
      "purpose": "Windows token-only GitHub persistence",
      "windows": "START.bat -> RUN.ps1 asks only GitHub token",
      "powershell_or_cmd": "Invoke-RestMethod PUT/GET",
      "linux_sandbox": "statically scanned; not executed without token",
      "equivalence": "BLOCK",
      "boundary": "Requires real token and GitHub API responses."
    },
    {
      "id": "MAP023_TOKEN_ONLY_POSIX_GITHUB",
      "purpose": "Linux/macOS token-only GitHub persistence",
      "windows": "RUN.ps1 token-only API persistence",
      "powershell_or_cmd": "PowerShell API PUT/GET",
      "linux_sandbox": "RUN.sh asks token and GH.py performs urllib API PUT/GET",
      "equivalence": "FUNCTIONAL",
      "boundary": "Requires python3 for POSIX GitHub API path and real token."
    }
  ],
  "verification_rule": "Every mapped item must be classified as EXACT, FUNCTIONAL, PARTIAL, or BLOCK. BLOCK items must not be claimed as successful.",
  "current_blocked_items": [
    "MAP013_GITHUB_API_GET",
    "MAP014_GITHUB_API_PUT",
    "MAP018_GITHUB_MAPPING_PERSISTENCE"
  ],
