    },
    "CC-BY-NC-ND-4.0": {
      "url": "https://creativecommons.org/licenses/by-nc-nd/4.0/legalcode.txt",
      "target_file": "LICENSES/CC-BY-NC-ND-4.0.txt",
      "applies_to": "non-software QIK-VRT content, documentation, policy, mapping, learning and bundle user information"
    }
  },
  "refresh_before_repository_persistence": true,
  "refresh_overwrites_existing_license_files": true,
